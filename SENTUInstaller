while true; do
    read -rp "¬ŅQuieres probar mi configuraci√≥n de nvim? (t/n): " try_nvim
    if [[ "$try_nvim" == "y" || "$try_nvim" == "n" ]]; then
        break
    else
        echo "Entrada inv√°lida. Por favor ingrese 'y' o 'n'."
    fi
done

printf "\nLos archivos de copia de seguridad se almacenar√°n en %s%s%s/.SENTUBackup%s \n\n" "${BLD}" "${CRE}" "$HOME" "${CNC}"
sleep 10

[ ! -d "$backup_folder" ] && mkdir -p "$backup_folder"

for folder in bspwm alacritty picom rofi eww sxhkd dunst kitty polybar ncmpcpp ranger tmux zsh mpd paru; do
    if [ -d "$HOME/.config/$folder" ]; then
        if mv "$HOME/.config/$folder" "$backup_folder/${folder}_$date" 2>> SENTUError.log; then
            printf "%s%s%s carpeta respaldada exitosamente en %s%s/%s_%s%s\n" "${BLD}" "${CGR}" "$folder" "${CBL}" "$backup_folder" "$folder" "$date" "${CNC}"
            sleep 1
        else
