        else
            printf "%s%sNo se pudo realizar la copia de seguridad del archivo user.js. Ver %sSENTUError.log%s\n" "${BLD}" "${CRE}" "${CBL}" "${CNC}"
        fi
    else
        printf "%s%sEl archivo user.js no existe, %sno se necesita copia de seguridad%s\n" "${BLD}" "${CGR}" "${CYE}" "${CNC}"
    fi
done

