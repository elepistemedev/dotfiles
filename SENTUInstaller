  sh ~/.dotfiles/scripts/login.sh
  echo "$mensaje"
  if sh "$script"; then
    echo "Ejecuci√≥n exitosa"
  else
    echo "**ERROR:** Fall√≥ la ejecuci√≥n de '$script'"
    exit 1
  fi
}

