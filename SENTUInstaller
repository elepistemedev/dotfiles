            sleep 1
        fi
    else
        printf "%s%s%s La carpeta no existe, %sno se necesita copia de seguridad.%s\n" "${BLD}" "${CGR}" "$folder" "${CYE}" "${CNC}"
        sleep 1
    fi
done

if [[ $try_nvim == "y" ]]; then
        # Backup nvim
    if [ -d "$HOME/.config/nvim" ]; then
        if mv "$HOME/.config/nvim" "$backup_folder/nvim_$date" 2>> SENTUError.log; then
                printf "%s%sCarpeta nvim respaldada exitosamente en %s%s/nvim_%s%s\n" "${BLD}" "${CGR}" "${CBL}" "$backup_folder" "$date" "${CNC}"
                sleep 1
            else
                printf "%s%sNo se pudo realizar la copia de seguridad de la carpeta nvim. Ver %sSENTUError.log%s\n" "${BLD}" "${CRE}" "${CBL}" "${CNC}"
                sleep 1
        fi
        else
            printf "%s%sLa carpeta nvim no existe, %sno se necesita copia de seguridad%s\n" "${BLD}" "${CGR}" "${CYE}" "${CNC}"
            sleep 1
    fi
fi

for folder in "$HOME"/.mozilla/firefox/*.default-release/chrome; do
    if [ -d "$folder" ]; then
        if mv "$folder" "$backup_folder"/chrome_"$date" 2>> SENTUError.log; then
            printf "%s%sCarpeta de Chrome respaldada exitosamente en %s%s/chrome_%s%s\n" "${BLD}" "${CGR}" "${CBL}" "$backup_folder" "${date}" "${CNC}"
        else
            printf "%s%sNo se pudo realizar la copia de seguridad de la carpeta Chrome. Ver %sSENTUError.log%s\n" "${BLD}" "${CRE}" "${CBL}" "${CNC}"
        fi
    else
        printf "%s%sLa carpeta Chrome no existe, %sno se necesita copia de seguridad%s\n" "${BLD}" "${CGR}" "${CYE}" "${CNC}"
    fi
