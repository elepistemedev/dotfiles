########## ---------- Cloning the SENTU! ---------- ##########

logo "Downloading dotfiles"

repo_url="https://github.com/elepistemedev/dotfiles"
repo_dir="$HOME/dotfiles"
branch_name="archlinux"

# Verifies if the folder of the repository exists, and if it does, deletes it
if [ -d "$repo_dir" ]; then
    printf "Eliminando el repositorio de dotfiles existente\n"
    rm -rf "$repo_dir"
fi

# Clone the repository
printf "Clonando dotfiles desde %s\n" "$repo_url"
git clone --branch "$branch_name" --depth=1 "$repo_url" "$repo_dir"
